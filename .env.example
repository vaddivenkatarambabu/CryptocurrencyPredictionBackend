# Optional local overrides.
# The project runs without a real .env file because these values are also defaults in code.

# Frontend
VITE_API_URL=http://127.0.0.1:5000

# Backend
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=false
MODEL_PATH=model.keras
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_TIMEOUT_SECONDS=10
HISTORY_DAYS=365
MAX_PREDICTION_DAYS=365
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5173,http://localhost:5173
RATE_LIMIT_DEFAULT=200 per hour
RATE_LIMIT_PREDICT=30 per minute
RATE_LIMIT_STORAGE_URI=memory://
LOG_LEVEL=INFO
